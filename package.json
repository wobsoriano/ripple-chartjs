{
	"name": "ripple-chartjs",
	"version": "0.1.1",
	"description": "Ripple components for Chart.js",
	"type": "module",
	"engines": {
		"node": ">=22.0.0"
	},
	"exports": {
		".": {
			"types": "./src/types/index.d.ts",
			"import": "./src/lib/index.ts",
			"default": "./src/lib/index.ts"
		}
	},
	"files": [
		"src/lib",
		"src/types"
	],
	"scripts": {
		"start": "vite",
		"dev": "vite",
		"build": "vite build",
		"lint": "eslint .",
		"serve": "vite preview",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"release": "bumpp && npm publish"
	},
	"license": "MIT",
	"devDependencies": {
		"@tsrx/eslint-parser": "latest",
		"@tsrx/eslint-plugin": "latest",
		"@tsrx/prettier-plugin": "latest",
		"@tsrx/typescript-plugin": "latest",
		"@typescript-eslint/parser": "^8.20.0",
		"@ripple-ts/vite-plugin": "latest",
		"bumpp": "^10.3.1",
		"chart.js": "^4.5.1",
		"eslint": "^9.0.0",
		"prettier": "^3.6.2",
		"ripple": "latest",
		"typescript": "^5.9.3",
		"vite": "^8.0.0"
	},
	"peerDependencies": {
		"chart.js": "^4.1.1",
		"ripple": "*"
	},
	"packageManager": "pnpm@10.20.0"
}
